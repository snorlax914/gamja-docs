PADDLEOCR_VLLM_URL=http://localhost:8118/v1
# pdf2image용 poppler bin 경로. 시스템 PATH에 poppler가 있으면 비워둬도 됨.
POPPLER_PATH=
# PaddleOCR 레이아웃 검출 디바이스: gpu | cpu (gpu는 paddlepaddle-gpu 필요)
PADDLE_DEVICE=cpu
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents
EMBEDDING_MODEL=BAAI/bge-m3
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
